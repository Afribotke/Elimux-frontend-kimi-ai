# ELIMUX ENVIRONMENT VARIABLES
# Copy to .env.local for development
# Add to Vercel Dashboard for production

NEXT_PUBLIC_APP_URL=https://elimux.ke
NEXT_PUBLIC_APP_NAME=ElimuX

# SUPABASE - Get from https://supabase.com/dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# BACKEND - Your Railway URL after deployment
NEXT_PUBLIC_BACKEND_URL=https://your-backend.railway.app

# STRIPE - Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# M-PESA
NEXT_PUBLIC_MPESA_ENABLED=true

# AI (ANTHROPIC) - Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
NEXT_PUBLIC_AI_ENABLED=true

# FEATURES
NEXT_PUBLIC_ENABLE_REVIEWS=true
NEXT_PUBLIC_ENABLE_GAMIFICATION=true
NEXT_PUBLIC_ENABLE_REFERRALS=true
NEXT_PUBLIC_ENABLE_SPONSOR_ADS=true
